{
  "productName": "Input0",
  "version": "0.5.0",
  "identifier": "com.input0",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Input0",
        "width": 960,
        "height": 640,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true
      },
      {
        "label": "overlay",
        "title": "Input0 Overlay",
        "url": "/overlay",
        "width": 800,
        "height": 200,
        "x": null,
        "y": null,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "focusable": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/*"],
    "createUpdaterArtifacts": true,
    "macOS": {
      "entitlements": "Entitlements.plist",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJDNDdGOTY4NzIwOTdENUIKUldSYmZRbHlhUGxITEVQYkFHSGFDNllMTzY3aEo0dTFIbmhWQk52L05HcDVWeEdacFRVRGgremoK",
      "endpoints": [
        "https://github.com/10xChengTu/input0/releases/latest/download/latest.json"
      ]
    }
  }
}
